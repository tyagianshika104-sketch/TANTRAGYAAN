# ── IBM Watsonx.ai (PRIMARY AI ENGINE) ───────────────────────────
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL=ibm/granite-13b-chat-v2

# ── IBM Watson NLU ──────────────────────────────────────────────
IBM_NLU_API_KEY=
IBM_NLU_URL=

# ── IBM Cloudant ────────────────────────────────────────────────
CLOUDANT_API_KEY=
CLOUDANT_URL=
CLOUDANT_DB_NAME=fundedfirst

# ── IBM Cloud Object Storage ────────────────────────────────────
COS_API_KEY=
COS_ENDPOINT=
COS_INSTANCE_CRN=
COS_BUCKET_NAME=fundedfirst-cvs

# ── IBM Text-to-Speech ──────────────────────────────────────────
IBM_TTS_API_KEY=
IBM_TTS_URL=

# ── IBM Speech-to-Text ──────────────────────────────────────────
IBM_STT_API_KEY=
IBM_STT_URL=

# ── Firebase Admin ──────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── Gemini (FALLBACK AI ONLY) ──────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── App Settings ────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=5000
APP_DEBUG=false
APP_SECRET_KEY=change-me-to-a-random-string

# ── Email (optional) ────────────────────────────────────────────
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_SMTP=smtp.gmail.com
EMAIL_PORT=587

# ── Telegram alerts (optional) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
